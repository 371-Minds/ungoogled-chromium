+class SentinelURLLoaderThrottle : public blink::URLLoaderThrottle {
+ public:
+  SentinelURLLoaderThrottle() {}
+  ~SentinelURLLoaderThrottle() override {}
+
+  void WillStartRequest(network::ResourceRequest* request, bool* defer) override {
+    // Filter all outbound cross-origin network payloads
+    if (request->url.host() == "localhost" || request->url.host() == "127.0.0.1") {
+      return;
+    }
+    
+    // Here we connect with the 371 Router at localhost:3001
+    // For example, by sending a request using network::SimpleURLLoader
+    // to http://localhost:3001/v1/sentinel/evaluate
+    // This intercepts the payload and awaits a verdict (APPROVE vs FLAG_HUMAN_REVIEW).
+    
+    // *defer = true;
+    // And resume the request in the callback.
+  }
+};
+
 std::vector<std::unique_ptr<content::URLLoaderThrottle>>
 ChromeContentBrowserClient::CreateURLLoaderThrottles(
     const network::ResourceRequest& request,
     content::BrowserContext* browser_context,
     const base::RepeatingCallback<content::WebContents*()>& wc_getter,
     content::NavigationUIData* navigation_ui_data,
     int frame_tree_node_id) {
   std::vector<std::unique_ptr<content::URLLoaderThrottle>> throttles;
+
+  throttles.push_back(std::make_unique<SentinelURLLoaderThrottle>());
+
   return throttles;
 }
