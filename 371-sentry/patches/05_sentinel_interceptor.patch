--- a/chrome/browser/chrome_content_browser_client.cc
+++ b/chrome/browser/chrome_content_browser_client.cc
@@ -2110,6 +2110,34 @@
+class SentinelURLLoaderThrottle : public content::URLLoaderThrottle {
+ public:
+  SentinelURLLoaderThrottle() {}
+  ~SentinelURLLoaderThrottle() override {}
+
+  void WillStartRequest(network::ResourceRequest* request, bool* defer) override {
+    // Allow requests to the local 371 Router itself to avoid recursion.
+    const std::string& host = request->url.host();
+    if (host == "localhost" || host == "127.0.0.1") {
+      return;
+    }
+
+    // Defer the request while we consult the 371 Router for a verdict.
+    *defer = true;
+
+    // Build the evaluation URL with the outbound target encoded as a query param.
+    GURL eval_url("https://localhost:3001/v1/sentinel/evaluate?url=" +
+                  net::EscapeQueryParamValue(request->url.spec(), /*use_plus=*/false));
+
+    auto resource_request = std::make_unique<network::ResourceRequest>();
+    resource_request->url = eval_url;
+    resource_request->method = "GET";
+    resource_request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+
+    url_loader_ = network::SimpleURLLoader::Create(std::move(resource_request),
+                                                   TRAFFIC_ANNOTATION_WITHOUT_PROTO(
+                                                       "sentinel_throttle",
+                                                       "371 Sentry outbound request evaluation"));
+    url_loader_->DownloadToString(
+        g_browser_process->system_network_context_manager()
+            ->GetURLLoaderFactory(),
+        base::BindOnce(&SentinelURLLoaderThrottle::OnVerdictReceived,
+                       weak_factory_.GetWeakPtr()),
+        /*max_body_size=*/4096);
+  }
+
+ private:
+  void OnVerdictReceived(std::unique_ptr<std::string> body) {
+    // If the router is unreachable or returns a non-APPROVE verdict, resume
+    // normally (fail-open). Callers that require fail-closed can change this.
+    url_loader_.reset();
+    delegate_->Resume();
+  }
+
+  std::unique_ptr<network::SimpleURLLoader> url_loader_;
+  base::WeakPtrFactory<SentinelURLLoaderThrottle> weak_factory_{this};
+};
+
 std::vector<std::unique_ptr<content::URLLoaderThrottle>>
 ChromeContentBrowserClient::CreateURLLoaderThrottles(
     const network::ResourceRequest& request,
     content::BrowserContext* browser_context,
     const base::RepeatingCallback<content::WebContents*()>& wc_getter,
     content::NavigationUIData* navigation_ui_data,
     int frame_tree_node_id) {
   std::vector<std::unique_ptr<content::URLLoaderThrottle>> throttles;
+
+  throttles.push_back(std::make_unique<SentinelURLLoaderThrottle>());
+
   return throttles;
 }
